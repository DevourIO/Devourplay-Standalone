{
  "name": "DevourPlay",
  "version": "0.1.0",
  "description": "DevourPlay – Play, earn, & unlock rewards while you game.",
  "main": "dist/browser/index.js",
  "author": {
    "name": "Devour",
    "email": "hello@devourgo.io"
  },
  "license": "MIT",
  "overwolf": {
    "packages": [
      "gep",
      "overlay"
    ]
  },
  "build": {
    "nodeGypRebuild": false,
    "appId": "com.overwolf.devourPlay",
    "protocols": {
      "name": "devourplay-protocol",
      "schemes": [
        "devourplay"
      ]
    },
    "asar": true,
    "overwolf": {
      "disableAdOptimization": false
    },
    "productName": "DevourPlay",
    "directories": {
      "output": "build"
    },
    "files": [
      "dist/**/*",
      "*.js",
      "*.html",
      "*.exe"
    ],
    "copyright": "Copyright 2023 Overwolf Ltd.",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "dist/assets/images/icon.ico",
      "artifactName": "${productName}-Setup-${version}.${ext}",
      "legalTrademarks": "Copyright 2023 Overwolf Ltd."
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "scripts": {
    "build:renderer": "webpack --config ./webpack.renderer.config.js",
    "build:main": "webpack --config ./webpack.main.config.js",
    "build": "cp -R src/assets dist && npx webpack --mode=development && npm run build:main && npm run build:renderer",
    "build:dev": "npx webpack --watch --mode=development",
    "build:start": "npm run build && ow-electron . ",
    "start": "ow-electron .",
    "build:ow-electron": "ow-electron-builder --c.extraMetadata.name=GameEventsTester --publish=never -mwl"
  },
  "devDependencies": {
    "@overwolf/ow-electron": "latest",
    "@overwolf/ow-electron-builder": "latest",
    "@overwolf/ow-electron-packages-types": "^0.0.5",
    "@types/jquery": "^3.5.16",
    "@types/jsonwebtoken": "^9.0.1",
    "@types/node": "^18.11.18",
    "copy-webpack-plugin": "^11.0.0",
    "electron": "41.0.3",
    "electron-updater": "^6.8.3",
    "html-webpack-plugin": "^5.5.0",
    "jest": "^29.3.1",
    "jest-environment-jsdom": "^29.3.1",
    "jest-junit": "^15.0.0",
    "jest-mock-extended": "^3.0.1",
    "reflect-metadata": "^0.1.13",
    "ts-jest": "^29.0.3",
    "ts-loader": "^9.4.2",
    "typescript": "^4.7.4",
    "typescript-logging": "^2.0.2",
    "webpack": "^5.75.0",
    "webpack-cli": "^5.0.1",
    "wrapper-webpack-plugin": "^2.1.0"
  },
  "dependencies": {
    "@devour/overwolf-sdk": "file:../overwolf-sdk"
  }
}
